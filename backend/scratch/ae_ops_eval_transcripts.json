{
  "_note": "Transcript-driven eval set for AE Ops Support workflows. Each case is a multi-turn conversation with expected behaviour at each turn. Run via scratch/run_ae_ops_evals.py against any workflow id. Designed to surface regressions on routing accuracy, NEED_INFO loop safety, no-hallucination, glossary use, audience awareness, and tool-call efficiency. Cases are tagged with `tier` (core | extended); `--tier` flag filters which run. `themes` field tags real-world theme coverage from the HDFC Life dataset (Monitoring/Stuck, Data/Report, File/Batch, Agent/Infra, Connectivity).",
  "_version": "2.0",
  "_v2_changes": "2026-05-02 — added tier metadata, themes, must_reach_status check; expanded from 12 to 33 cases covering both business + tech personas including conversational tech-chat patterns; informed by HDFC Life real-ticket dataset (39,682 tickets) and the MS Teams claim-status reference flow.",
  "cases": [
    {
      "id": "missing-identifier-business-glossary-match",
      "tier": "core",
      "themes": ["data_report"],
      "description": "Business user asks about a missing report using business language — glossary should match, Worker should investigate by workflow_id, no NEED_INFO needed.",
      "user_role": "business",
      "turns": [
        {
          "input": "I haven't received my daily recon report this morning",
          "expect": {
            "intent_in": ["ops", "output_missing"],
            "tool_family_any": ["ae.workflow", "ae.request", "glossary"],
            "must_include_any": ["recon", "report"],
            "must_exclude": ["request_id", "workflow_id", "agent_id", "JSON"],
            "max_iterations": 6
          }
        }
      ]
    },
    {
      "id": "missing-identifier-business-vague",
      "tier": "core",
      "themes": ["monitoring"],
      "description": "Business user with no glossary match — Worker should ask ONE targeted question, not investigate, and not re-ask on the next turn.",
      "user_role": "business",
      "turns": [
        {
          "input": "which requests have failed recently",
          "expect": {
            "intent_in": ["ops"],
            "must_include_any": ["which", "what", "report", "system"],
            "must_end_with_question": true,
            "must_exclude": ["request_id", "workflow_id"],
            "tool_calls_max": 1,
            "max_iterations": 3,
            "entity_grounding_required": true
          }
        },
        {
          "input": "log analyzer",
          "expect": {
            "must_not_re_ask": true,
            "tool_family_any": ["ae.workflow", "ae.request"],
            "must_exclude": ["request_id", "workflow_id"],
            "max_iterations": 6,
            "entity_grounding_required": true
          }
        },
        {
          "input": "yesterday",
          "expect": {
            "must_not_re_ask": true,
            "tool_family_any": ["ae.workflow", "ae.request"],
            "must_include_any": ["yesterday", "log analyzer"],
            "max_iterations": 6,
            "entity_grounding_required": true
          }
        }
      ]
    },
    {
      "id": "tech-specific-request-id",
      "tier": "core",
      "themes": ["monitoring"],
      "description": "Tech user gives an exact request_id — Worker investigates, surfaces findings, may cite IDs and tool names. Capped at 4 tool calls to guard against the over-investigation regression.",
